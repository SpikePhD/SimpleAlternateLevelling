    "xp_base":     5.0,
    "xp_increase": 1.0,
    "xp_cap":      500.0,
    "_comment": "xp_base maps to fXPLevelUpBase, xp_increase to fXPLevelUpMult.",
    "_comment_formula": "threshold(level) = min(xp_cap, xp_base + level * xp_increase)",
    "_comment_vanilla": "Vanilla defaults: xp_base=75, xp_increase=25 (no cap).",
    "_comment_cap": "xp_cap clamps the threshold so leveling never becomes a chore at high levels.",
